{
  "name": "Synchronisation Google Contacts → Baserow",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "GET",
        "path": "sync-google-contacts",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "n01",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "sync-google-contacts"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://people.googleapis.com/v1/people/me/connections",
        "authentication": "genericCredentialType",
        "genericAuthType": "oAuth2Api",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "personFields", "value": "names,emailAddresses,phoneNumbers,organizations" },
            { "name": "pageSize",     "value": "1000" }
          ]
        },
        "options": {}
      },
      "id": "n02",
      "name": "Google Contacts",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [460, 300],
      "credentials": {
        "oAuth2Api": {
          "id": "REMPLACER_PAR_TON_CREDENTIAL_ID",
          "name": "Google OAuth2 (People API)"
        }
      }
    },
    {
      "parameters": {
        "fieldToSplitOut": "connections",
        "options": {}
      },
      "id": "n03",
      "name": "Extraire",
      "type": "n8n-nodes-base.splitOut",
      "typeVersion": 1,
      "position": [680, 300]
    },
    {
      "parameters": {
        "mode": "manual",
        "assignments": {
          "assignments": [
            { "id": "a1", "name": "prenom",     "value": "={{ $json.names?.[0]?.givenName ?? '' }}",                "type": "string" },
            { "id": "a2", "name": "nom",        "value": "={{ $json.names?.[0]?.familyName ?? '' }}",               "type": "string" },
            { "id": "a3", "name": "email",      "value": "={{ ($json.emailAddresses?.[0]?.value ?? '').trim() }}",  "type": "string" },
            { "id": "a4", "name": "telephone",  "value": "={{ $json.phoneNumbers?.[0]?.value ?? '' }}",             "type": "string" },
            { "id": "a5", "name": "entreprise", "value": "={{ $json.organizations?.[0]?.name ?? '' }}",             "type": "string" }
          ]
        },
        "options": {}
      },
      "id": "n04",
      "name": "Mapper",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [900, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "loose" },
          "conditions": [
            { "id": "c1", "leftValue": "={{ $json.email }}", "rightValue": "", "operator": { "type": "string", "operation": "notEmpty" } }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "n05",
      "name": "Filtrer",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2.2,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "batchSize": 1,
        "options": {}
      },
      "id": "n06",
      "name": "Lots",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [1340, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://baserow.ananda-communaute.cloud/api/database/rows/table/544/",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "Token GBLdzaCZvQUVXkCqSls3WX3dT3uVg0H8" }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "user_field_names",     "value": "true" },
            { "name": "filter__Email__equal", "value": "={{ $json.email }}" }
          ]
        },
        "options": {}
      },
      "id": "n07",
      "name": "Chercher",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1560, 160]
    },
    {
      "parameters": {
        "mode": "manual",
        "assignments": {
          "assignments": [
            { "id": "b1", "name": "_count",     "value": "={{ $json.count }}",                         "type": "number" },
            { "id": "b2", "name": "_id",        "value": "={{ $json.results?.[0]?.id ?? 0 }}",          "type": "number" },
            { "id": "b3", "name": "prenom",     "value": "={{ $('Lots').item.json.prenom }}",           "type": "string" },
            { "id": "b4", "name": "nom",        "value": "={{ $('Lots').item.json.nom }}",              "type": "string" },
            { "id": "b5", "name": "email",      "value": "={{ $('Lots').item.json.email }}",            "type": "string" },
            { "id": "b6", "name": "telephone",  "value": "={{ $('Lots').item.json.telephone }}",        "type": "string" },
            { "id": "b7", "name": "entreprise", "value": "={{ $('Lots').item.json.entreprise }}",       "type": "string" }
          ]
        },
        "options": {}
      },
      "id": "n08",
      "name": "Fusionner",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1780, 160]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            { "id": "d1", "leftValue": "={{ $json._count }}", "rightValue": 0, "operator": { "type": "number", "operation": "gt" } }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "n09",
      "name": "Existe",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [2000, 160]
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "={{ 'https://baserow.ananda-communaute.cloud/api/database/rows/table/544/' + $json._id + '/?user_field_names=true' }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "Token GBLdzaCZvQUVXkCqSls3WX3dT3uVg0H8" }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "keypair",
        "bodyParameters": {
          "parameters": [
            { "name": "Prénom",     "value": "={{ $json.prenom }}" },
            { "name": "Nom",        "value": "={{ $json.nom }}" },
            { "name": "Téléphone",  "value": "={{ $json.telephone }}" },
            { "name": "Entreprise", "value": "={{ $json.entreprise }}" }
          ]
        },
        "options": {}
      },
      "id": "n10",
      "name": "Modifier",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [2220, 60]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://baserow.ananda-communaute.cloud/api/database/rows/table/544/?user_field_names=true",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "Token GBLdzaCZvQUVXkCqSls3WX3dT3uVg0H8" }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "keypair",
        "bodyParameters": {
          "parameters": [
            { "name": "Prénom",     "value": "={{ $json.prenom }}" },
            { "name": "Nom",        "value": "={{ $json.nom }}" },
            { "name": "Email",      "value": "={{ $json.email }}" },
            { "name": "Téléphone",  "value": "={{ $json.telephone }}" },
            { "name": "Entreprise", "value": "={{ $json.entreprise }}" },
            { "name": "Catégorie",  "value": "Admin" }
          ]
        },
        "options": {}
      },
      "id": "n11",
      "name": "Creer",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [2220, 280]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"ok\": true, \"message\": \"Synchronisation terminee\" }",
        "options": {
          "responseHeaders": {
            "entries": [
              { "name": "Access-Control-Allow-Origin", "value": "*" }
            ]
          }
        }
      },
      "id": "n12",
      "name": "Reponse",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1560, 460]
    }
  ],
